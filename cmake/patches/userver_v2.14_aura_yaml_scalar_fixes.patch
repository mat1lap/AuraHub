+std::size_t YamlAsSizeT(const yaml_config::YamlConfig& v) {
+    if (v.IsString()) {
+        return static_cast<std::size_t>(std::stoull(v.As<std::string>(), nullptr, 10));
+    }
+    if (v.IsDouble()) {
+        const double d = v.As<double>();
+        if (!std::isfinite(d) || std::trunc(d) != d || d < 0) {
+            throw std::runtime_error("size_t field: expected a non-negative whole number");
+        }
+        return static_cast<std::size_t>(d);
+    }
+    return v.As<std::size_t>();
+}
