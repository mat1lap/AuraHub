+bool IsLooseInteger(const yaml_config::YamlConfig& value) {
+    if (value.IsInt() || value.IsUInt64() || value.IsInt64()) {
+        return true;
+    }
+    if (value.IsDouble()) {
+        const double d = value.As<double>();
+        return std::isfinite(d) && std::trunc(d) == d;
+    }
+    if (value.IsString()) {
+        const auto s = value.As<std::string>();
+        char* end = nullptr;
+        errno = 0;
+        (void)std::strtoull(s.c_str(), &end, 10);
+        return errno == 0 && end == s.c_str() + s.size() && !s.empty();
+    }
+    return false;
+}
